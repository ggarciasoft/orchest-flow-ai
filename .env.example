# OrchestAI — Environment Variables
# Copy this file to .env and fill in the values.
# Never commit .env to source control.

# ─── Backend (OrchestAI.Api) ───────────────────────────────────────────────

# JWT signing secret — must be at least 32 characters
JWT_KEY=change-me-to-a-long-random-secret-at-least-32-chars

# JWT issuer and audience (should match frontend config)
JWT_ISSUER=orchestai-api
JWT_AUDIENCE=orchestai-web

# LLM Provider — set to "openai" for real calls, "fake" for local dev without API key
LLM_PROVIDER=fake

# OpenAI API key — required when LLM_PROVIDER=openai
OPENAI_API_KEY=sk-...

# OpenAI default model
OPENAI_DEFAULT_MODEL=gpt-4o

# Database connection string — required when PostgreSQL is wired up
# CONNECTION_STRING=Host=localhost;Database=orchestai;Username=postgres;Password=postgres

# ─── Frontend (apps/web) ───────────────────────────────────────────────────

# Backend API base URL used by the Next.js frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:5080
