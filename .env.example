# Example environment variables — copy to .env for local/Docker usage.

# ── Database ──────────────────────────────────────────────────────────────────
CONNECTIONSTRING__DEFAULT=Host=localhost;Database=OrchestFlowAI;Username=OrchestFlowAI;Password=OrchestFlowAI

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Auth (JWT) ────────────────────────────────────────────────────────────────
# Must be at least 32 characters — change in production!
JWT_KEY=dev-signing-key-change-in-production-32chars
JWT_ISSUER=OrchestFlowAI
JWT_AUDIENCE=OrchestFlowAI-web

# ── Encryption ────────────────────────────────────────────────────────────────
# Used for encrypting secrets at rest — change in production!
ENCRYPTION_MASTER_KEY=dev-encryption-key-change-in-production

# ── AI / LLM ─────────────────────────────────────────────────────────────────
# LLM_PROVIDER options: fake | openai | anthropic | azure | ollama
LLM_PROVIDER=fake
OPENAI_API_KEY=
OPENAI_DEFAULT_MODEL=gpt-4o-mini

# ── Observability ─────────────────────────────────────────────────────────────
# Grafana admin password (default: admin)
GRAFANA_PASSWORD=admin
